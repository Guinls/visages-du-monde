# Variables d'environnement publiques (préfixe NEXT_PUBLIC_ uniquement si exposées au client)
# Aucune clé secrète ne doit être placée dans des variables NEXT_PUBLIC_*.

# URL canonique du site (utilisée pour les métadonnées OpenGraph / canonical)
NEXT_PUBLIC_SITE_URL=https://www.visagesdumonde-brest.fr

# Téléphone de l'agence (affiché sur la page, format international pour tel:)
NEXT_PUBLIC_AGENCE_PHONE=+33200000000

# Lien Clic RDV (réservation de rendez-vous)
NEXT_PUBLIC_CLICRDV_URL=https://user.clicrdv.com/vdm-brest
